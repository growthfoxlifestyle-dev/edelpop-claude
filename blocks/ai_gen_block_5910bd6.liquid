{% doc %}
  @prompt
    Create a hero image carousel/slider section that displays multiple images (at least 2) with smooth sliding transitions. It should support auto-play, navigation arrows, and dot indicators. The carousel should be fully responsive and work well on mobile. It should allow merchants to configure each slide with an image, heading text, subheading, and a CTA button. Match the premium, bold aesthetic of a gourmet snack brand.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-hero-carousel-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    overflow: hidden;
    display: block;
  }

  .ai-hero-carousel__viewport-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    height: {{ block.settings.desktop_height }}px;
  }

  .ai-hero-carousel__track-{{ ai_gen_id }} {
    display: flex;
    transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);
    height: 100%;
  }

  .ai-hero-carousel__slide-{{ ai_gen_id }} {
    min-width: 100%;
    height: 100%;
    position: relative;
    display: flex;
    align-items: {{ block.settings.content_alignment_vertical }};
    justify-content: {{ block.settings.content_alignment_horizontal }};
  }

  .ai-hero-carousel__image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-hero-carousel__image-placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, #f4f4f4 0%, #e0e0e0 100%);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-hero-carousel__image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 400px;
    max-height: 400px;
    opacity: 0.3;
  }

  .ai-hero-carousel__overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: {{ block.settings.overlay_color }};
    opacity: {{ block.settings.overlay_opacity | divided_by: 100.0 }};
    pointer-events: none;
  }

  .ai-hero-carousel__content-{{ ai_gen_id }} {
    position: relative;
    z-index: 2;
    text-align: {{ block.settings.text_alignment }};
    max-width: {{ block.settings.content_max_width }}px;
    padding: 40px 20px;
  }

  .ai-hero-carousel__heading-{{ ai_gen_id }} {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 600;
    font-size: {{ block.settings.heading_size }}px;
    line-height: 1.1;
    margin: 0 0 16px;
    text-transform: uppercase;
    letter-spacing: 0.02em;
  }

  .ai-hero-carousel__subheading-{{ ai_gen_id }} {
    font-size: {{ block.settings.subheading_size }}px;
    line-height: 1.5;
    margin: 0 0 24px;
  }

  .ai-hero-carousel__button-{{ ai_gen_id }} {
    display: inline-block;
    padding: 14px 32px;
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 600;
    font-size: {{ block.settings.button_size }}px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    text-decoration: none;
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_text_color }};
    border: none;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .ai-hero-carousel__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background }};
    color: {{ block.settings.button_hover_text_color }};
  }

  .ai-hero-carousel__controls-{{ ai_gen_id }} {
    position: absolute;
    bottom: 30px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 3;
    display: flex;
    gap: 12px;
    align-items: center;
  }

  .ai-hero-carousel__dot-{{ ai_gen_id }} {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background-color: {{ block.settings.dot_color }};
    opacity: 0.5;
    border: none;
    cursor: pointer;
    padding: 0;
    transition: all 0.3s ease;
  }

  .ai-hero-carousel__dot-{{ ai_gen_id }}.active {
    opacity: 1;
    transform: scale(1.2);
  }

  .ai-hero-carousel__arrow-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 3;
    background-color: {{ block.settings.arrow_background }};
    color: {{ block.settings.arrow_color }};
    border: none;
    width: 50px;
    height: 50px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.3s ease;
    opacity: 0.8;
  }

  .ai-hero-carousel__arrow-{{ ai_gen_id }}:hover {
    opacity: 1;
    background-color: {{ block.settings.arrow_hover_background }};
  }

  .ai-hero-carousel__arrow-{{ ai_gen_id }}--prev {
    left: 20px;
  }

  .ai-hero-carousel__arrow-{{ ai_gen_id }}--next {
    right: 20px;
  }

  .ai-hero-carousel__arrow-{{ ai_gen_id }} svg {
    width: 24px;
    height: 24px;
  }

  @media screen and (max-width: 749px) {
    .ai-hero-carousel__viewport-{{ ai_gen_id }} {
      height: {{ block.settings.mobile_height }}px;
    }

    .ai-hero-carousel__heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.6 }}px;
    }

    .ai-hero-carousel__subheading-{{ ai_gen_id }} {
      font-size: {{ block.settings.subheading_size | times: 0.85 }}px;
    }

    .ai-hero-carousel__button-{{ ai_gen_id }} {
      font-size: {{ block.settings.button_size | times: 0.9 }}px;
      padding: 12px 24px;
    }

    .ai-hero-carousel__content-{{ ai_gen_id }} {
      padding: 30px 16px;
    }

    .ai-hero-carousel__arrow-{{ ai_gen_id }} {
      width: 40px;
      height: 40px;
    }

    .ai-hero-carousel__arrow-{{ ai_gen_id }}--prev {
      left: 10px;
    }

    .ai-hero-carousel__arrow-{{ ai_gen_id }}--next {
      right: 10px;
    }

    .ai-hero-carousel__controls-{{ ai_gen_id }} {
      bottom: 20px;
    }
  }
{% endstyle %}

<hero-carousel-{{ ai_gen_id }} class="ai-hero-carousel-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-hero-carousel__viewport-{{ ai_gen_id }}">
    <div class="ai-hero-carousel__track-{{ ai_gen_id }}">
      {% for i in (1..5) %}
        {% liquid
          assign slide_enabled_key = 'slide_' | append: i | append: '_enabled'
          assign slide_image_key = 'slide_' | append: i | append: '_image'
          assign slide_heading_key = 'slide_' | append: i | append: '_heading'
          assign slide_subheading_key = 'slide_' | append: i | append: '_subheading'
          assign slide_button_text_key = 'slide_' | append: i | append: '_button_text'
          assign slide_button_link_key = 'slide_' | append: i | append: '_button_link'
          assign slide_heading_color_key = 'slide_' | append: i | append: '_heading_color'
          assign slide_text_color_key = 'slide_' | append: i | append: '_text_color'

          assign slide_enabled = block.settings[slide_enabled_key]
          assign slide_image = block.settings[slide_image_key]
          assign slide_heading = block.settings[slide_heading_key]
          assign slide_subheading = block.settings[slide_subheading_key]
          assign slide_button_text = block.settings[slide_button_text_key]
          assign slide_button_link = block.settings[slide_button_link_key]
          assign slide_heading_color = block.settings[slide_heading_color_key]
          assign slide_text_color = block.settings[slide_text_color_key]
        %}

        {% if slide_enabled %}
          <div class="ai-hero-carousel__slide-{{ ai_gen_id }}" data-slide="{{ i }}">
            {% if slide_image %}
              <img
                src="{{ slide_image | image_url: width: 2000 }}"
                alt="{{ slide_image.alt | escape }}"
                loading="lazy"
                width="{{ slide_image.width }}"
                height="{{ slide_image.height }}"
                class="ai-hero-carousel__image-{{ ai_gen_id }}"
              >
            {% else %}
              <div class="ai-hero-carousel__image-placeholder-{{ ai_gen_id }}">
                {{ 'hero-apparel-1' | placeholder_svg_tag }}
              </div>
            {% endif %}

            <div class="ai-hero-carousel__overlay-{{ ai_gen_id }}"></div>

            <div class="ai-hero-carousel__content-{{ ai_gen_id }}">
              {% if slide_heading != blank %}
                <h2 class="ai-hero-carousel__heading-{{ ai_gen_id }}" style="color: {{ slide_heading_color }};">
                  {{ slide_heading }}
                </h2>
              {% endif %}

              {% if slide_subheading != blank %}
                <p class="ai-hero-carousel__subheading-{{ ai_gen_id }}" style="color: {{ slide_text_color }};">
                  {{ slide_subheading }}
                </p>
              {% endif %}

              {% if slide_button_text != blank %}
                <a
                  href="{{ slide_button_link }}"
                  class="ai-hero-carousel__button-{{ ai_gen_id }}"
                >
                  {{ slide_button_text }}
                </a>
              {% endif %}
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>

    {% if block.settings.show_arrows %}
      <button
        class="ai-hero-carousel__arrow-{{ ai_gen_id }} ai-hero-carousel__arrow-{{ ai_gen_id }}--prev"
        aria-label="Previous slide"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="15 18 9 12 15 6"></polyline>
        </svg>
      </button>

      <button
        class="ai-hero-carousel__arrow-{{ ai_gen_id }} ai-hero-carousel__arrow-{{ ai_gen_id }}--next"
        aria-label="Next slide"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="9 18 15 12 9 6"></polyline>
        </svg>
      </button>
    {% endif %}

    {% if block.settings.show_dots %}
      <div class="ai-hero-carousel__controls-{{ ai_gen_id }}">
        {% for i in (1..5) %}
          {% liquid
            assign slide_enabled_key = 'slide_' | append: i | append: '_enabled'
            assign slide_enabled = block.settings[slide_enabled_key]
          %}
          {% if slide_enabled %}
            <button
              class="ai-hero-carousel__dot-{{ ai_gen_id }}"
              data-slide="{{ i }}"
              aria-label="Go to slide {{ i }}"
            ></button>
          {% endif %}
        {% endfor %}
      </div>
    {% endif %}
  </div>
</hero-carousel-{{ ai_gen_id }}>

<script>
  (function() {
    class HeroCarousel{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.currentSlide = 0;
        this.autoplayInterval = null;
        this.isTransitioning = false;
      }

      connectedCallback() {
        this.track = this.querySelector('.ai-hero-carousel__track-{{ ai_gen_id }}');
        this.slides = this.querySelectorAll('.ai-hero-carousel__slide-{{ ai_gen_id }}');
        this.dots = this.querySelectorAll('.ai-hero-carousel__dot-{{ ai_gen_id }}');
        this.prevButton = this.querySelector('.ai-hero-carousel__arrow-{{ ai_gen_id }}--prev');
        this.nextButton = this.querySelector('.ai-hero-carousel__arrow-{{ ai_gen_id }}--next');
        this.autoplayEnabled = {{ block.settings.autoplay }};
        this.autoplaySpeed = {{ block.settings.autoplay_speed }} * 1000;

        if (this.slides.length === 0) return;

        this.setupEventListeners();
        this.updateSlide(0);

        if (this.autoplayEnabled && this.slides.length > 1) {
          this.startAutoplay();
        }
      }

      setupEventListeners() {
        if (this.prevButton) {
          this.prevButton.addEventListener('click', () => this.previousSlide());
        }

        if (this.nextButton) {
          this.nextButton.addEventListener('click', () => this.nextSlide());
        }

        this.dots.forEach((dot, index) => {
          dot.addEventListener('click', () => this.goToSlide(index));
        });

        this.addEventListener('mouseenter', () => this.stopAutoplay());
        this.addEventListener('mouseleave', () => {
          if (this.autoplayEnabled && this.slides.length > 1) {
            this.startAutoplay();
          }
        });

        let touchStartX = 0;
        let touchEndX = 0;

        this.addEventListener('touchstart', (e) => {
          touchStartX = e.changedTouches[0].screenX;
        });

        this.addEventListener('touchend', (e) => {
          touchEndX = e.changedTouches[0].screenX;
          this.handleSwipe(touchStartX, touchEndX);
        });
      }

      handleSwipe(startX, endX) {
        const swipeThreshold = 50;
        const diff = startX - endX;

        if (Math.abs(diff) > swipeThreshold) {
          if (diff > 0) {
            this.nextSlide();
          } else {
            this.previousSlide();
          }
        }
      }

      updateSlide(index) {
        if (this.isTransitioning) return;
        this.isTransitioning = true;

        this.currentSlide = index;
        const offset = -index * 100;
        this.track.style.transform = `translateX(${offset}%)`;

        this.dots.forEach((dot, i) => {
          if (i === index) {
            dot.classList.add('active');
          } else {
            dot.classList.remove('active');
          }
        });

        setTimeout(() => {
          this.isTransitioning = false;
        }, 600);
      }

      nextSlide() {
        const nextIndex = (this.currentSlide + 1) % this.slides.length;
        this.updateSlide(nextIndex);
      }

      previousSlide() {
        const prevIndex = (this.currentSlide - 1 + this.slides.length) % this.slides.length;
        this.updateSlide(prevIndex);
      }

      goToSlide(index) {
        this.updateSlide(index);
      }

      startAutoplay() {
        this.stopAutoplay();
        this.autoplayInterval = setInterval(() => {
          this.nextSlide();
        }, this.autoplaySpeed);
      }

      stopAutoplay() {
        if (this.autoplayInterval) {
          clearInterval(this.autoplayInterval);
          this.autoplayInterval = null;
        }
      }

      disconnectedCallback() {
        this.stopAutoplay();
      }
    }

    customElements.define('hero-carousel-{{ ai_gen_id }}', HeroCarousel{{ ai_gen_id }});
  })();
</script>

